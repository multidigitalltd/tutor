<?xml version="1.0"?>
<ruleset name="DeSchool">
	<description>Multi Digital coding standard for the DeSchool plugin.</description>

	<file>md-deschool</file>

	<!-- Scan only PHP files. -->
	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Warnings are advisory; only errors fail the build. -->
	<config name="ignore_warnings_on_exit" value="1"/>

	<!-- WordPress full standard. -->
	<rule ref="WordPress"/>

	<!-- PHP 8.3+ and WP 6.4+ compatibility. -->
	<config name="testVersion" value="8.3-"/>
	<rule ref="PHPCompatibilityWP"/>
	<config name="minimum_supported_wp_version" value="6.4"/>

	<!-- Plugin text domain. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="md-deschool"/>
			</property>
		</properties>
	</rule>

	<!-- Prefixes for globals/hooks. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="mdds"/>
				<element value="MultiDigital\DeSchool"/>
			</property>
		</properties>
	</rule>

	<!-- Recognise the plugin's custom iframe sanitiser. -->
	<rule ref="WordPress.Security.ValidatedSanitizedInput">
		<properties>
			<property name="customSanitizingFunctions" type="array">
				<element value="sanitize_embed"/>
			</property>
		</properties>
	</rule>

	<!--
		Template parts are included within Template_Loader's scope and receive
		their variables from the loader, so PHPCS's file-scope variable sniffs
		(unprefixed / global-override) are false positives there.
	-->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound">
		<exclude-pattern>*/templates/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.WP.GlobalVariablesOverride.Prohibited">
		<exclude-pattern>*/templates/*</exclude-pattern>
	</rule>

	<!-- Chapter/unit queries intentionally set an explicit posts_per_page. -->
	<rule ref="WordPress.WP.PostsPerPage">
		<severity>0</severity>
	</rule>

	<!-- Decorative section-separator block comments. -->
	<rule ref="Squiz.Commenting.BlockComment.CloserSameLine">
		<severity>0</severity>
	</rule>

	<!--
		Nonce is verified centrally before any $_POST processing: the AJAX
		handlers go through guard() (check_ajax_referer) and the metabox save()
		methods call wp_verify_nonce up-front, then read $_POST in helpers. PHPCS
		cannot trace that across methods, so the sniff is a false positive here.
	-->
	<rule ref="WordPress.Security.NonceVerification">
		<exclude-pattern>*/includes/frontend/class-ajax.php</exclude-pattern>
		<exclude-pattern>*/includes/admin/class-unit-metaboxes.php</exclude-pattern>
		<exclude-pattern>*/includes/admin/class-chapter-metaboxes.php</exclude-pattern>
	</rule>

	<!-- Ignore third-party/build paths. -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
</ruleset>
